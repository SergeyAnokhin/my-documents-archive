{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "frontend-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "3001"],
      "cwd": "frontend",
      "port": 3001
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["run.py"],
      "cwd": "backend",
      "port": 8000
    }
  ]
}
