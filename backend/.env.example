# ── Document library ─────────────────────────────────────────────────────────
# Root folder for all documents. The app creates YYYY/MM/ subdirs for uploads.
# .docintell/ (SQLite, ChromaDB, thumbnails) lives inside this folder.
#
# Local dev (Windows, SMB drive mapped as Z:):
#   LIBRARY_PATH=C:\REPOS\Temp\MyDocumentsTest
#
# Local dev (Linux / WSL, SMB mounted):
#   LIBRARY_PATH=/mnt/nas/my-documents
#
# Production (k8s): set via Helm values.yaml → backend.libraryPath
#   (injected as LIBRARY_PATH env var in the pod)
LIBRARY_PATH=./library

# ── OCR ──────────────────────────────────────────────────────────────────────
# OCR_ENGINE=tesseract          # "tesseract" (default, local) | "external"
# EXTERNAL_OCR_URL=http://localhost:8001

# ── AI provider API keys (fallback when no providers are configured in Admin UI)
# Anthropic is configured via Admin UI only — no env-var fallback.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# MISTRAL_API_KEY=...
